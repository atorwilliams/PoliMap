      "appointingParty": "Liberal",
      "appointmentDate": "2018-03-12",
      "leaning": "unknown",
      "knownBias": "",
      "notableCases": [
        {
          "name": "Vriend v Alberta  1 SCR 493",
          "year": 1998,
          "description": "The Supreme Court of Canada ruled that Alberta’s human rights law violated the Charter by failing to protect people from discrimination on the basis of sexual orientation.\nThe Court ordered “sexual orientation” to be read into the legislation as a prohibited ground of discrimination."
        },
        {
          "name": "R v Ewanchuk",
          "year": 1999,
          "description": "The Supreme Court of Canada held that consent to sexual activity must be affirmative, voluntary, and ongoing, and that silence, passivity, or lack of resistance does not constitute consent.\nThe Court rejected the defence of “implied consent” and overturned the acquittal in the sexual assault case."
        }
      ],
      "notes": "Elevated to Chief Justice of Alberta on November 25, 2022.",
      "portrait": "https://cba.org/CBA/media/cba-org-Images/Sections/Madam%20Justice/JC-Khullar-Portrait.jpg"
