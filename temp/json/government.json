  "platforms": [
    {
      "topic": "Energy & Environment",
      "ucp": "Defend and expand Alberta's oil, gas, and coal industries. Oppose federal emissions caps. Pursue carbon capture and storage. Challenge federal jurisdiction over energy through the Alberta Sovereignty Act.",
      "ndp": "Managed transition away from fossil fuels while protecting workers. Support renewable energy development. Respect federal climate targets. Repeal the Sovereignty Act."
    },
    {
      "topic": "Healthcare",
      "ucp": "Expand private surgical facilities to reduce wait times. Split health portfolio into hospital and primary care streams. Maintain public funding while allowing private delivery.",
      "ndp": "Rebuild and fully fund the public healthcare system. Reverse privatization. Hire more nurses and doctors. Oppose two-tier care."
    },
    {
      "topic": "Education",
      "ucp": "Support school choice and charter schools. Reform K–6 curriculum. Parental rights in education. Fund private and faith-based schools.",
      "ndp": "Restore public education funding. Oppose the revised K–6 curriculum. Strengthen public school system. Limit public funding to private schools."
    },
    {
      "topic": "Economy & Taxes",
      "ucp": "No provincial sales tax. Low corporate taxes to attract investment. Reduce red tape. Grow the Heritage Fund through energy revenues.",
      "ndp": "Progressive taxation. Increase corporate tax rate. Invest Heritage Fund revenues in public services. Address cost of living through affordability programs."
    },
    {
      "topic": "Federal Relations",
      "ucp": "Assert provincial jurisdiction aggressively. Challenge federal overreach via the Sovereignty Act. Seek greater autonomy on tax collection, pension, and policing.",
      "ndp": "Cooperate with the federal government. Repeal the Sovereignty Act. Pursue Alberta's interests through negotiation, not confrontation."
    },
    {
      "topic": "Indigenous Relations",
      "ucp": "Consult on resource development. Support economic reconciliation through energy industry participation. Meet treaty obligations.",
      "ndp": "Implement UNDRIP. Free, prior and informed consent for resource projects. Increase funding for Indigenous communities, language, and culture."
    },
    {
      "topic": "Housing & Affordability",
      "ucp": "Cut red tape to speed up housing construction. Affordability rebates. Oppose rent control as a barrier to supply.",
      "ndp": "Build affordable and social housing. Explore rent stabilization. Fund housing supports for low-income Albertans."
    },
    {
      "topic": "Separatism",
      "ucp": "Officially oppose separation but use sovereignty rhetoric as leverage. The Sovereignty Act asserts Alberta can refuse federal laws deemed unconstitutional. Smith has called for a referendum on an Alberta pension plan and provincial police force — steps toward autonomy short of independence.",
      "ndp": "Firmly oppose separation and sovereignty act brinkmanship. Nenshi has called separatist rhetoric 'a distraction.' The NDP favours asserting Alberta's interests through federal engagement and court challenges rather than unilateral defiance."
    }
  ]
